{
  "name": "manor",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --filter manor-desktop tauri dev",
    "build": "pnpm --filter manor-desktop tauri build",
    "tsc": "pnpm --filter manor-desktop tsc",
    "fmt": "cargo fmt && pnpm -r exec prettier --write 'src/**/*.{ts,tsx,css,html}' || true",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings"
  },
  "engines": {
    "node": ">=20"
  }
}
